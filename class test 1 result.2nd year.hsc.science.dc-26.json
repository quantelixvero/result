    <!-- Minimized Trigger Button -->
    <div id="minimizedModalBtn" class="floating-trigger">
      <i class="fas fa-bell"></i> Stay Updated
    </div>

    <script>
      document.addEventListener("DOMContentLoaded", () => {
        const modal = document.getElementById("socialModal");
        const closeBtn = document.getElementById("closeModal");
        const minimizedBtn = document.getElementById("minimizedModalBtn");

        // Function to show modal and hide minimized button
        function showModal() {
          modal.classList.add("show");
          minimizedBtn.classList.remove("show");
        }

        // Function to hide modal and show minimized button
        function minimizeModal() {
          modal.classList.remove("show");
          minimizedBtn.classList.add("show");
        }

        // Show modal automatically on load after a delay
        setTimeout(() => {
          showModal();
        }, 1500);

        // Close button -> Minimize
        closeBtn.addEventListener("click", minimizeModal);

        // Click outside -> Minimize
        modal.addEventListener("click", (e) => {
          if (e.target === modal) {
            minimizeModal();
          }
        });

        // Click minimized button -> Show Modal
        minimizedBtn.addEventListener("click", showModal);
      });
    </script>
